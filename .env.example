# Server-only OpenAI credential and optional model names.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_REVIEW_MODEL=

# Server-only Tavily credential.
TAVILY_API_KEY=

# Supabase project origin and server-only service-role credential.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated, server-only list of Supabase Auth email addresses authorized as Miller administrators.
ADMIN_EMAIL_ALLOWLIST=

# Comma-separated exact frontend origins allowed to call Express when frontend and backend use different origins.
CORS_ALLOWED_ORIGINS=

# Temporary public preview password. Keep configured until public access is explicitly approved.
SITE_PASSWORD=

# Feature flag for server-side AI resource review.
AI_REVIEW_ENABLED=

# Express runtime configuration.
PORT=
NODE_ENV=
